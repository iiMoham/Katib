# Copy this file to `keystore.properties` (which is gitignored) and fill in
# the real values after you create your upload keystore:
#
#   keytool -genkeypair -v -keystore katib-upload.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias katib-upload
#
# storeFile is resolved relative to the `android/` folder.

storeFile=katib-upload.jks
storePassword=CHANGE_ME
keyAlias=katib-upload
keyPassword=CHANGE_ME
