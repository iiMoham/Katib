# Copy this file to `secrets.properties` (which is gitignored) to override the
# release proxy settings without committing anything.
#
# PROXY_BASE_URL : your deployed proxy. Leave unset to use the build.gradle default.
# PROXY_API_KEY  : the shared secret. Must EXACTLY match the PROXY_API_KEY env var
#                  on your Railway proxy. Leave blank to disable the gate.

PROXY_BASE_URL=https://katib-production-0352.up.railway.app
PROXY_API_KEY=PASTE_YOUR_PROXY_API_KEY_HERE
