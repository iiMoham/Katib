# === LLM provider ===
# Pick ONE provider. All three speak the OpenAI-compatible API, so switching is just config.
#
#   xai     -> Grok        (paid)          key: https://console.x.ai
#   groq    -> Llama/Qwen  (FREE tier)     key: https://console.groq.com/keys
#   gemini  -> Gemini      (FREE tier)     key: https://aistudio.google.com/apikey
#
LLM_PROVIDER=xai
LLM_API_KEY=your-key-here
# Optional overrides (leave blank to use the provider's sensible default model/URL):
#   xai default model    = grok-2-latest
#   groq default model   = llama-3.3-70b-versatile   (try qwen-2.5-32b for better Arabic)
#   gemini default model = gemini-2.0-flash
LLM_MODEL=
LLM_BASE_URL=
# Set to false only if a provider rejects response_format=json_object (xai/groq/gemini all accept it).
JSON_MODE=true

# --- Legacy xAI-only vars (still honoured if LLM_* are unset) ---
# XAI_API_KEY=xai-your-key-here
# GROK_MODEL=grok-2-latest

# === Server ===
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed origins for CORS. Use * for any (dev only).
CORS_ORIGINS=*

# === Behaviour ===
# Max characters of user text accepted per request (privacy + cost guard).
MAX_TEXT_LENGTH=600
# In-memory LRU cache size (number of distinct text/mode/task results kept).
CACHE_SIZE=50
# Per-call timeout to the Grok API, seconds.
REQUEST_TIMEOUT=12
# Sampling temperature for the model (lower = more deterministic corrections).
TEMPERATURE=0.2

# === Optional: simple shared-secret auth between the app and this proxy ===
# If set, clients must send header  X-Katib-Key: <this value>
# Leave blank to disable.
PROXY_API_KEY=
