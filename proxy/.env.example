# === xAI Grok ===
# Get your key from https://console.x.ai
XAI_API_KEY=xai-your-key-here
XAI_BASE_URL=https://api.x.ai/v1
# Model name. Common options: grok-2-latest, grok-3, grok-4, grok-4-fast.
# If you get a "model not found" error, change this to a model your account has access to.
GROK_MODEL=grok-2-latest

# === Server ===
HOST=0.0.0.0
PORT=8000
# Comma-separated list of allowed origins for CORS. Use * for any (dev only).
CORS_ORIGINS=*

# === Behaviour ===
# Max characters of user text accepted per request (privacy + cost guard).
MAX_TEXT_LENGTH=600
# In-memory LRU cache size (number of distinct text/mode/task results kept).
CACHE_SIZE=50
# Per-call timeout to the Grok API, seconds.
REQUEST_TIMEOUT=12
# Sampling temperature for the model (lower = more deterministic corrections).
TEMPERATURE=0.2

# === Optional: simple shared-secret auth between the app and this proxy ===
# If set, clients must send header  X-Katib-Key: <this value>
# Leave blank to disable.
PROXY_API_KEY=
